generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // url        = env("DATABASE_URL")
  extensions = [vector]
}

model Role {
  id              String      @id @default(cuid())
  title           String
  category        String
  level           String
  industry        String
  job_description String
  metadata        Json?
  full_jd_text    String?
  content_embedding Unsupported("vector(3072)")?
  created_at        DateTime    @default(now())
  candidates      Candidate[]
}

model Rubric {
  id         String   @id @default(cuid())
  category   String
  parameter  String
  poor       String
  borderline String?
  good       String
  strong     String
  content_embedding Unsupported("vector(3072)")?
  created_at        DateTime @default(now())

  @@unique([category, parameter])
}

model Candidate {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  resume_url   String?
  role_id      String
  role         Role        @relation(fields: [role_id], references: [id])
  stage        String
  profile_data Json?
  content_embedding Unsupported("vector(3072)")?
  created_at        DateTime    @default(now())
  interviews   Interview[]
}

model Interview {
  id                String             @id @default(cuid())
  candidate_id      String
  candidate         Candidate          @relation(fields: [candidate_id], references: [id])
  interviewer_email String
  round_type        String
  scheduled_time    DateTime
  status            String
  feedback          InterviewFeedback?
}

model InterviewFeedback {
  id             String    @id @default(cuid())
  interview_id   String    @unique
  interview      Interview @relation(fields: [interview_id], references: [id])
  transcript     String?
  rating         Int?
  recommendation String?
  comments       String?
  created_at     DateTime  @default(now())
}
