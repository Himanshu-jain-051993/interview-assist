generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

model Role {
  id              String      @id @default(cuid())
  title           String
  category        String
  level           String
  industry        String
  job_description String
  metadata        Json?
  full_jd_text    String?
  content_embedding Unsupported("vector(3072)")?
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt
  candidates       Candidate[]
  interview_guides InterviewGuide[]
  interview_rounds InterviewRound[]
}


model Rubric {
  id         String   @id @default(cuid())
  category   String
  parameter  String
  poor       String
  borderline String?
  good       String
  strong     String
  content_embedding Unsupported("vector(3072)")?
  created_at        DateTime @default(now())

  @@unique([category, parameter])
}

model Candidate {
  id                 String      @id @default(cuid())
  name               String
  email              String      @unique
  resume_url         String?
  role_id            String
  role               Role        @relation(fields: [role_id], references: [id])
  stage              String
  resume_score       Float?
  resume_review_data Json?
  raw_resume_text    String?
  profile_data       Json?
  content_embedding Unsupported("vector(3072)")?
  created_at         DateTime    @default(now())
  status_updated_at  DateTime    @default(now())
  interviews         Interview[]
  transcripts        InterviewTranscript[]
  interview_guides   InterviewGuide[]
  interview_rounds   InterviewRound[]
}


model Interview {
  id                String             @id @default(cuid())
  candidate_id      String
  candidate         Candidate          @relation(fields: [candidate_id], references: [id])
  interviewer_email String
  round_type        String
  scheduled_time    DateTime
  status            String
  feedback          InterviewFeedback?
}

model InterviewFeedback {
  id             String    @id @default(cuid())
  interview_id   String    @unique
  interview      Interview @relation(fields: [interview_id], references: [id])
  transcript     String?
  rating         Int?
  recommendation String?
  comments       String?
  created_at     DateTime  @default(now())
}

model InterviewTranscript {
  id               String    @id @default(cuid())
  candidate_id     String
  candidate        Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  raw_text         String
  synthesized_json Json?
  processed_at     DateTime  @default(now())
}

model InterviewGuide {
  id           String    @id @default(cuid())
  candidate_id String
  role_id      String
  guide_data   Json
  generated_at DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  candidate    Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  role         Role      @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([candidate_id, role_id])
}

model InterviewRound {
  id                String    @id @default(cuid())
  candidate_id      String
  role_id           String
  round_type        String    // Screening | Technical_1 | Technical_2 | Culture_Fit
  interview_date    DateTime?
  transcript_text   String?
  interviewer_notes String?
  ai_feedback_json  Json?
  cumulative_score  Float?
  created_at        DateTime  @default(now())
  candidate         Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  role              Role      @relation(fields: [role_id], references: [id], onDelete: Cascade)
}

